{
  "name": "structured-doc-editor",
  "displayName": "Structured Doc Editor",
  "description": "WYSIWYG editor for .sdoc files with automatic AsciiDoc conversion",
  "version": "0.1.0",
  "publisher": "your-publisher-name",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "structuredDocEditor.sdoc",
        "displayName": "Structured Doc Editor",
        "selector": [
          {
            "filenamePattern": "*.sdoc"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "structuredDocEditor.exportToHtml",
        "title": "Export to HTML",
        "category": "Structured Doc"
      },
      {
        "command": "structuredDocEditor.exportToAdoc",
        "title": "Export to AsciiDoc",
        "category": "Structured Doc"
      },
      {
        "command": "structuredDocEditor.exportToMarkdown",
        "title": "Export to Markdown",
        "category": "Structured Doc"
      }
    ],
    "configuration": {
      "title": "Structured Doc Editor",
      "properties": {
        "structuredDocEditor.document.defaultAuthor": {
          "type": "string",
          "default": "",
          "description": "Default author name for new .sdoc documents (used in metadata)"
        },
        "structuredDocEditor.caption.imagePrefix": {
          "type": "string",
          "default": "Image",
          "description": "Prefix for image captions (e.g., 'Image', 'Figure', 'Fig.', '그림')"
        },
        "structuredDocEditor.caption.tablePrefix": {
          "type": "string",
          "default": "Table",
          "description": "Prefix for table captions (e.g., 'Table', '표')"
        },
        "structuredDocEditor.caption.numbering": {
          "type": "string",
          "default": "simple",
          "enum": ["simple", "hierarchical"],
          "enumDescriptions": [
            "Simple sequential numbering (1, 2, 3, ...)",
            "Hierarchical numbering based on heading sections (1.1, 1.2, 2.1, ...)"
          ],
          "description": "Caption numbering style for images and tables"
        },
        "structuredDocEditor.heading.numbering": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic heading numbering (1., 1.1, 1.1.1, ...)"
        },
        "structuredDocEditor.image.defaultAlignment": {
          "type": "string",
          "default": "center",
          "enum": ["left", "center", "right"],
          "description": "Default alignment when inserting new images"
        },
        "structuredDocEditor.export.imagePath": {
          "type": "string",
          "default": "relative",
          "enum": ["relative", "absolute"],
          "enumDescriptions": [
            "Use relative paths for images (e.g., ./images/photo.png)",
            "Use absolute file system paths for images"
          ],
          "description": "Image path format in exported documents"
        },
        "structuredDocEditor.theme.companyLogo": {
          "type": "string",
          "default": "",
          "description": "Company logo URL or base64 encoded image for HTML export header"
        },
        "structuredDocEditor.theme.companyName": {
          "type": "string",
          "default": "",
          "description": "Company name to display in HTML export header"
        },
        "structuredDocEditor.theme.primaryColor": {
          "type": "string",
          "default": "#2563eb",
          "description": "Primary color for headings and table headers in HTML export"
        },
        "structuredDocEditor.theme.accentColor": {
          "type": "string",
          "default": "#1e40af",
          "description": "Accent color for secondary headings in HTML export"
        },
        "structuredDocEditor.theme.fontFamily": {
          "type": "string",
          "default": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif",
          "description": "Font family for HTML export"
        },
        "structuredDocEditor.theme.customStyles": {
          "type": "string",
          "default": "",
          "description": "Custom CSS styles for HTML export (advanced users)"
        }
      }
    }
  },
  "workspaces": [
    "webview-ui"
  ],
  "scripts": {
    "build": "npm run build:ext && npm run build:webview",
    "build:ext": "node esbuild.mjs",
    "build:webview": "npm run build --workspace=webview-ui",
    "watch:ext": "node esbuild.mjs --watch",
    "watch:webview": "npm run build --workspace=webview-ui -- --watch",
    "watch": "npm-run-all --parallel watch:ext watch:webview",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "asciidoctor": "^3.0.4",
    "esbuild": "^0.20.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.3.3"
  }
}
