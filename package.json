{
  "name": "structured-doc-editor",
  "displayName": "Structured Doc Editor",
  "description": "WYSIWYG editor for .tiptap.json/.sdoc files with Markdown/AsciiDoc/HTML export",
  "version": "0.4.19",
  "publisher": "swbaek",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SWBaek/sdoc-editor.git"
  },
  "homepage": "https://github.com/SWBaek/sdoc-editor#readme",
  "bugs": {
    "url": "https://github.com/SWBaek/sdoc-editor/issues"
  },
  "keywords": [
    "sdoc",
    "tiptap",
    "wysiwyg",
    "structured-document",
    "markdown",
    "asciidoc"
  ],
  "icon": "media/sdoc-editor-icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "structuredDocEditor.sdoc",
        "displayName": "Structured Doc Editor",
        "selector": [
          {
            "filenamePattern": "*.tiptap.json"
          },
          {
            "filenamePattern": "*.sdoc"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "structuredDocEditor.sdocBook",
        "displayName": "Sdoc Book Editor",
        "selector": [
          {
            "filenamePattern": "*.sdocbook"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "structuredDocEditor.newSdoc",
        "title": "New .sdoc Document (Experimental Templates)",
        "category": "Structured Doc"
      },
      {
        "command": "structuredDocEditor.exportToHtml",
        "title": "Export to HTML",
        "category": "Structured Doc"
      },
      {
        "command": "structuredDocEditor.exportToAdoc",
        "title": "Export to AsciiDoc",
        "category": "Structured Doc"
      },
      {
        "command": "structuredDocEditor.exportToMarkdown",
        "title": "Export to Markdown",
        "category": "Structured Doc"
      },
      {
        "command": "structuredDocEditor.exportToPdf",
        "title": "Export to PDF",
        "category": "Structured Doc"
      },
      {
        "command": "structuredDocEditor.exportToSlides",
        "title": "Export to Slides",
        "category": "Structured Doc"
      }
    ],
    "configuration": {
      "title": "Structured Doc Editor",
      "properties": {
        "structuredDocEditor.caption.style": {
          "type": "string",
          "default": "modern",
          "enum": [
            "ieee",
            "iso",
            "modern",
            "korean"
          ],
          "enumDescriptions": [
            "IEEE (간결형): Fig. 1, Table I, (1)",
            "ISO/IEC (정석형): Figure 1, Table 1, Equation (1)",
            "Modern (현대형): Figure 1, Table 1, Equation 1",
            "Korean (한국형): 그림 1, 표 1, 식 (1)"
          ],
          "description": "Caption style preset that controls prefixes, separators, table number format, and equation parentheses"
        },
        "structuredDocEditor.caption.crossRefIncludeCaption": {
          "type": "boolean",
          "default": false,
          "description": "Include caption text in cross-reference labels (e.g., 'Figure 1: Title' instead of 'Figure 1')"
        },
        "structuredDocEditor.caption.numbering": {
          "type": "string",
          "default": "sequential",
          "enum": [
            "sequential",
            "hierarchical"
          ],
          "enumDescriptions": [
            "Sequential numbering (1, 2, 3, ...)",
            "Hierarchical numbering based on heading sections (1.1, 1.2, 2.1, ...)"
          ],
          "description": "Caption numbering style for images, tables, and equations"
        },
        "structuredDocEditor.equation.numbering": {
          "type": "string",
          "default": "sequential",
          "enum": [
            "sequential",
            "hierarchical"
          ],
          "enumDescriptions": [
            "Sequential numbering across the document: (1), (2), (3), ...",
            "Hierarchical numbering per H1 section: (1.1), (1.2), (2.1), ..."
          ],
          "description": "Numbering style for block equations"
        },
        "structuredDocEditor.heading.numbering": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic heading numbering (1., 1.1, 1.1.1, ...)"
        },
        "structuredDocEditor.heading.decoration": {
          "type": "boolean",
          "default": true,
          "description": "Show heading decorations (border-bottom for H1)"
        },
        "structuredDocEditor.heading.h1Color": {
          "type": "string",
          "default": "#2563EB",
          "pattern": "^#[0-9a-fA-F]{3,8}$",
          "markdownDescription": "H1 heading numbering 및 decoration 색상 (hex 형식). 예: `#2563EB` (Blue), `#333333`, `#569cd6`"
        },
        "structuredDocEditor.heading.h2Color": {
          "type": "string",
          "default": "#2563EB",
          "pattern": "^#[0-9a-fA-F]{3,8}$",
          "markdownDescription": "H2 heading numbering 색상 (hex 형식). 예: `#2563EB` (Blue), `#6b6b6b` (Gray)"
        },
        "structuredDocEditor.heading.h3Color": {
          "type": "string",
          "default": "#2563EB",
          "pattern": "^#[0-9a-fA-F]{3,8}$",
          "markdownDescription": "H3 heading numbering 색상 (hex 형식). 예: `#2563EB` (Blue), `#6b6b6b` (Gray)"
        },
        "structuredDocEditor.heading.h4Color": {
          "type": "string",
          "default": "#2563EB",
          "pattern": "^#[0-9a-fA-F]{3,8}$",
          "markdownDescription": "H4 heading numbering 색상 (hex 형식). 예: `#2563EB` (Blue), `#6b6b6b` (Gray)"
        },
        "structuredDocEditor.heading.h5Color": {
          "type": "string",
          "default": "#2563EB",
          "pattern": "^#[0-9a-fA-F]{3,8}$",
          "markdownDescription": "H5 heading numbering 색상 (hex 형식). 예: `#2563EB` (Blue), `#6b6b6b` (Gray)"
        },
        "structuredDocEditor.heading.h6Color": {
          "type": "string",
          "default": "#2563EB",
          "pattern": "^#[0-9a-fA-F]{3,8}$",
          "markdownDescription": "H6 heading numbering 색상 (hex 형식). 예: `#2563EB` (Blue), `#6b6b6b` (Gray)"
        },
        "structuredDocEditor.image.defaultAlignment": {
          "type": "string",
          "default": "center",
          "enum": [
            "left",
            "center",
            "right"
          ],
          "description": "Default alignment when inserting new images"
        },
        "structuredDocEditor.export.imagePath": {
          "type": "string",
          "default": "relative",
          "enum": [
            "relative",
            "absolute"
          ],
          "enumDescriptions": [
            "Use relative paths for images (e.g., ./images/photo.png)",
            "Use absolute file system paths for images"
          ],
          "description": "Image path format in exported documents"
        },
        "structuredDocEditor.export.selfContained": {
          "type": "string",
          "default": "images-only",
          "enum": [
            "none",
            "images-only",
            "full"
          ],
          "enumDescriptions": [
            "No embedding — use relative/absolute image paths",
            "Embed images as base64 data URIs (default). CDN links for KaTeX/Mermaid",
            "Embed everything: images + KaTeX + Mermaid scripts inline (~2MB larger)"
          ],
          "description": "Self-contained HTML export level"
        },
        "structuredDocEditor.export.pdfScale": {
          "type": "number",
          "default": 70,
          "minimum": 10,
          "maximum": 200,
          "description": "PDF export scale percentage (10–200). Default 70% produces a well-proportioned output."
        },
        "structuredDocEditor.export.outputDir": {
          "type": "string",
          "default": "",
          "description": "Optional export output directory. Relative paths are resolved from the workspace folder, then the document folder."
        },
        "structuredDocEditor.theme.companyLogo": {
          "type": "string",
          "default": "",
          "description": "Optional logo URL or base64 data URI for the HTML export header"
        },
        "structuredDocEditor.theme.companyName": {
          "type": "string",
          "default": "Structured Doc",
          "description": "Company name to display in HTML export header"
        },
        "structuredDocEditor.theme.primaryColor": {
          "type": "string",
          "default": "#2563EB",
          "description": "Primary color for headings and table headers in HTML export"
        },
        "structuredDocEditor.theme.accentColor": {
          "type": "string",
          "default": "#6b6b6b",
          "description": "Accent color for secondary headings in HTML export"
        },
        "structuredDocEditor.theme.fontFamily": {
          "type": "string",
          "default": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
          "description": "Font family for the editor and HTML/PDF export"
        },
        "structuredDocEditor.font.body": {
          "type": "string",
          "enum": [
            "Light",
            "Regular",
            "SemiBold",
            "Bold"
          ],
          "default": "Regular",
          "enumDescriptions": [
            "Light (300) — 가벼운 본문",
            "Regular (400) — 기본 본문",
            "SemiBold (600) — 약간 굵은 본문",
            "Bold (700) — 굵은 본문"
          ],
          "description": "본문 텍스트의 폰트 굵기"
        },
        "structuredDocEditor.font.bold": {
          "type": "string",
          "enum": [
            "Light",
            "Regular",
            "SemiBold",
            "Bold"
          ],
          "default": "Bold",
          "enumDescriptions": [
            "Light (300)",
            "Regular (400)",
            "SemiBold (600) — 본문과 적절한 대비",
            "Bold (700) — 강한 강조"
          ],
          "description": "Bold(강조) 텍스트의 폰트 굵기"
        },
        "structuredDocEditor.font.h1": {
          "type": "string",
          "enum": [
            "Light",
            "Regular",
            "SemiBold",
            "Bold"
          ],
          "default": "Bold",
          "enumDescriptions": [
            "Light (300)",
            "Regular (400)",
            "SemiBold (600)",
            "Bold (700) — 가장 큰 제목에 적합"
          ],
          "description": "H1 제목의 폰트 굵기"
        },
        "structuredDocEditor.font.h2": {
          "type": "string",
          "enum": [
            "Light",
            "Regular",
            "SemiBold",
            "Bold"
          ],
          "default": "SemiBold",
          "enumDescriptions": [
            "Light (300)",
            "Regular (400)",
            "SemiBold (600) — H1보다 한 단계 가볍게",
            "Bold (700)"
          ],
          "description": "H2 제목의 폰트 굵기"
        },
        "structuredDocEditor.font.h3": {
          "type": "string",
          "enum": [
            "Light",
            "Regular",
            "SemiBold",
            "Bold"
          ],
          "default": "SemiBold",
          "enumDescriptions": [
            "Light (300)",
            "Regular (400)",
            "SemiBold (600)",
            "Bold (700)"
          ],
          "description": "H3 제목의 폰트 굵기"
        },
        "structuredDocEditor.theme.customStyles": {
          "type": "string",
          "default": "",
          "description": "Custom CSS styles for HTML export (advanced users)"
        },
        "structuredDocEditor.slide.breakLevel": {
          "type": "string",
          "enum": [
            "h1-only",
            "h1-h2-vertical"
          ],
          "default": "h1-only",
          "enumDescriptions": [
            "H1 제목만 슬라이드 경계로 사용 (H2/H3는 같은 슬라이드 내 소제목)",
            "H1 = 수평 슬라이드, H2 = 수직 슬라이드 (reveal.js 수직 탐색)"
          ],
          "description": "슬라이드 페이지 분리 기준"
        },
        "structuredDocEditor.slide.showTitleSlide": {
          "type": "boolean",
          "default": true,
          "description": "문서 메타데이터(Title, Author, Version)로 타이틀 슬라이드를 자동 생성합니다"
        },
        "structuredDocEditor.slide.primaryColor": {
          "type": "string",
          "default": "",
          "pattern": "^(#[0-9a-fA-F]{3,8})?$",
          "markdownDescription": "슬라이드 전용 메인 색상 (비워두면 `theme.primaryColor` 사용)"
        },
        "structuredDocEditor.slide.accentColor": {
          "type": "string",
          "default": "",
          "pattern": "^(#[0-9a-fA-F]{3,8})?$",
          "markdownDescription": "슬라이드 전용 보조 색상 (비워두면 `theme.accentColor` 사용)"
        },
        "structuredDocEditor.slide.transition": {
          "type": "string",
          "enum": [
            "none",
            "fade",
            "slide",
            "convex",
            "concave",
            "zoom"
          ],
          "default": "none",
          "enumDescriptions": [
            "애니메이션 없이 즉시 전환",
            "페이드 인/아웃 (가장 부드러움)",
            "좌우 슬라이드",
            "볼록 효과 (3D)",
            "오목 효과 (3D)",
            "확대/축소 효과"
          ],
          "description": "슬라이드 전환 애니메이션"
        }
      }
    }
  },
  "workspaces": [
    "webview-ui",
    "tauri-app"
  ],
  "scripts": {
    "build": "npm run validators:generate && npm run build:ext && npm run build:webview",
    "build:all": "npm run build && npm run build:desktop",
    "build:ext": "node esbuild.mjs",
    "build:webview": "npm run build --workspace=webview-ui",
    "build:desktop": "npm run build --workspace=sdoc-editor-tauri",
    "package": "node scripts/package-vsix.mjs",
    "typecheck": "npm run typecheck:core && npm run typecheck --workspaces --if-present",
    "typecheck:core": "tsc --noEmit",
    "lint": "eslint src shared webview-ui/src tauri-app/src",
    "lint:fix": "npm run lint -- --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "version:check": "node scripts/check-versions.mjs",
    "check": "npm run version:check && npm run validators:check && npm run typecheck && npm run lint && npm test",
    "licenses:generate": "node scripts/generate-third-party-notices.mjs",
    "licenses:check": "node scripts/generate-third-party-notices.mjs --check",
    "release:check-artifacts": "node scripts/check-release-artifacts.mjs",
    "validators:generate": "node scripts/generate-document-validators.mjs",
    "validators:check": "node scripts/generate-document-validators.mjs --check",
    "watch:ext": "node esbuild.mjs --watch",
    "watch:webview": "npm run build --workspace=webview-ui -- --watch",
    "watch": "npm-run-all --parallel watch:ext watch:webview",
    "clean:dist": "node -e \"const fs=require('fs'),p=require('path'),d='dist';fs.readdirSync(d).filter(f=>f.endsWith('.map')).forEach(f=>fs.rmSync(p.join(d,f)));const a=p.join(d,'webview','assets');try{fs.readdirSync(a).filter(f=>f.startsWith('KaTeX')&&f.endsWith('.ttf')).forEach(f=>fs.rmSync(p.join(a,f)))}catch{}\"",
    "vscode:prepublish": "npm run build && npm run clean:dist"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vscode/vsce": "3.9.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "highlight.js": "^11.11.1",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1"
  }
}
