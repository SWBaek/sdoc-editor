{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri-conf-schema-v2/refs/heads/main/tauri.conf.json",
  "productName": "Structured Doc Editor",
  "version": "0.4.21",
  "identifier": "io.github.swbaek.sdoc-editor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Structured Doc Editor",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' asset: http://asset.localhost blob: data:; connect-src 'self' ipc: http://ipc.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "copyright": "Copyright © 2026 SWBaek and Structured Doc Editor contributors",
    "resources": {
      "../../LICENSE": "LICENSE.txt",
      "../../THIRD_PARTY_NOTICES.md": "THIRD_PARTY_NOTICES.md",
      "../../licenses/fonts/Pretendard-OFL.txt": "FONT_LICENSES/Pretendard-OFL.txt",
      "../../licenses/fonts/JetBrainsMono-OFL.txt": "FONT_LICENSES/JetBrainsMono-OFL.txt"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "fileAssociations": [
      {
        "ext": ["sdoc"],
        "mimeType": "application/json",
        "description": "Structured Document"
      },
      {
        "ext": ["tiptap.json"],
        "mimeType": "application/json",
        "description": "Tiptap Document"
      }
    ]
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "shell": {
      "open": true
    }
  }
}
