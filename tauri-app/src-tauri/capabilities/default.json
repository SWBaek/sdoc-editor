{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Structured Doc Editor",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-confirm",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-read-text-file",
    "fs:allow-write-file",
    "fs:allow-write-text-file",
    "fs:allow-create",
    "fs:allow-rename",
    "fs:allow-remove",
    "fs:allow-exists",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-stat",
    "fs:allow-lstat",
    "fs:allow-copy-file",
    "fs:read-all",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "**" }]
    },
    "shell:default",
    "shell:allow-open",
    "process:default",
    "process:allow-exit",
    "process:allow-restart"
  ]
}
