                "type": "tableCell",
                "attrs": { "colspan": 1, "rowspan": 1 },
                "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "—" }] }]
              }
            ]
          }
        ]
      },

      {
        "type": "paragraph",
        "attrs": { "textAlign": "center" },
        "content": [
          { "type": "text", "text": "— End of Feature Guide —", "marks": [{ "type": "italic" }, { "type": "textStyle", "attrs": { "color": "#868e96" } }] }
        ]
      }
    ]
  }
}
