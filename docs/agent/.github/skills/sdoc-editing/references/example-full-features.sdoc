        "content": [{ "type": "text", "text": "코드 블록" }]
      },
      {
        "type": "paragraph",
        "content": [
          { "type": "text", "text": "다양한 프로그래밍 언어의 구문 강조(Syntax Highlighting)를 지원합니다. highlight.js 기반으로 100개 이상의 언어를 지원합니다." }
        ]
      },

      {
        "type": "heading",
        "attrs": { "level": 2, "id": "python-code" },
        "content": [{ "type": "text", "text": "Python" }]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "python" },
        "content": [{ "type": "text", "text": "import numpy as np\nfrom dataclasses import dataclass\n\n@dataclass\nclass Vector:\n    x: float\n    y: float\n    z: float\n\n    def magnitude(self) -> float:\n        \"\"\"벡터의 크기를 계산합니다.\"\"\"\n        return np.sqrt(self.x**2 + self.y**2 + self.z**2)\n\n    def normalize(self) -> 'Vector':\n        mag = self.magnitude()\n        return Vector(self.x / mag, self.y / mag, self.z / mag)\n\n# 사용 예시\nv = Vector(3.0, 4.0, 0.0)\nprint(f\"크기: {v.magnitude()}\")   # 5.0\nprint(f\"단위벡터: {v.normalize()}\")  # Vector(0.6, 0.8, 0.0)" }]
      },

      {
        "type": "heading",
        "attrs": { "level": 2, "id": "typescript-code" },
        "content": [{ "type": "text", "text": "TypeScript" }]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "typescript" },
        "content": [{ "type": "text", "text": "interface DocumentNode {\n  type: string;\n  attrs?: Record<string, unknown>;\n  content?: DocumentNode[];\n  marks?: Mark[];\n  text?: string;\n}\n\ninterface Mark {\n  type: string;\n  attrs?: Record<string, unknown>;\n}\n\nfunction traverseNodes(node: DocumentNode, visitor: (n: DocumentNode) => void): void {\n  visitor(node);\n  if (node.content) {\n    for (const child of node.content) {\n      traverseNodes(child, visitor);\n    }\n  }\n}\n\n// 모든 텍스트 노드를 추출하는 예시\nconst texts: string[] = [];\ntraverseNodes(doc, (node) => {\n  if (node.type === 'text' && node.text) {\n    texts.push(node.text);\n  }\n});" }]
      },

      {
        "type": "heading",
        "attrs": { "level": 2, "id": "rust-code" },
        "content": [{ "type": "text", "text": "Rust" }]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "rust" },
        "content": [{ "type": "text", "text": "use serde::{Deserialize, Serialize};\n\n#[derive(Serialize, Deserialize, Debug)]\nstruct SdocEnvelope {\n    sdoc: String,\n    meta: Meta,\n    doc: DocNode,\n}\n\n#[derive(Serialize, Deserialize, Debug)]\nstruct Meta {\n    title: String,\n    author: String,\n    version: String,\n}\n\n#[derive(Serialize, Deserialize, Debug)]\nstruct DocNode {\n    #[serde(rename = \"type\")]\n    node_type: String,\n    content: Option<Vec<DocNode>>,\n}\n\nfn main() -> Result<(), Box<dyn std::error::Error>> {\n    let json = std::fs::read_to_string(\"example.sdoc\")?;\n    let doc: SdocEnvelope = serde_json::from_str(&json)?;\n    println!(\"Document: {}\", doc.meta.title);\n    Ok(())\n}" }]
      },

      {
        "type": "heading",
        "attrs": { "level": 2, "id": "sql-code" },
        "content": [{ "type": "text", "text": "SQL" }]
      },
      {
        "type": "codeBlock",
        "attrs": { "language": "sql" },
        "content": [{ "type": "text", "text": "-- 문서 메타데이터 테이블\nCREATE TABLE documents (\n    id          SERIAL PRIMARY KEY,\n    title       VARCHAR(255) NOT NULL,\n    author      VARCHAR(100),\n    version     VARCHAR(20) DEFAULT '1.0',\n    created_at  TIMESTAMP DEFAULT CURRENT_TIMESTAMP,\n    modified_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP\n);\n\n-- 최근 수정된 문서 조회\nSELECT d.title, d.author, d.modified_at\nFROM documents d\nWHERE d.modified_at > NOW() - INTERVAL '7 days'\nORDER BY d.modified_at DESC\nLIMIT 10;" }]
      },

      {
        "type": "heading",
