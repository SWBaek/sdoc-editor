          { "type": "text", "text": "으로 텍스트 색상을 변경할 수 있습니다." }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          { "type": "text", "text": "배경 하이라이트: " },
          { "type": "text", "text": "노란색 하이라이트", "marks": [{ "type": "highlight", "attrs": { "color": "#fff3bf" } }] },
          { "type": "text", "text": ", " },
          { "type": "text", "text": "초록색 하이라이트", "marks": [{ "type": "highlight", "attrs": { "color": "#b2f2bb" } }] },
          { "type": "text", "text": ", " },
          { "type": "text", "text": "분홍색 하이라이트", "marks": [{ "type": "highlight", "attrs": { "color": "#fcc2d7" } }] },
          { "type": "text", "text": ", " },
          { "type": "text", "text": "파란색 하이라이트", "marks": [{ "type": "highlight", "attrs": { "color": "#a5d8ff" } }] },
          { "type": "text", "text": "를 적용할 수 있습니다." }
