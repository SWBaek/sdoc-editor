      {
        "type": "paragraph",
        "content": [
          { "type": "text", "text": "여러 마크를 동시에 적용할 수 있습니다: " },
          { "type": "text", "text": "굵고 기울임", "marks": [{ "type": "bold" }, { "type": "italic" }] },
          { "type": "text", "text": ", " },
          { "type": "text", "text": "굵고 밑줄", "marks": [{ "type": "bold" }, { "type": "underline" }] },
          { "type": "text", "text": ", " },
          { "type": "text", "text": "기울이고 취소선", "marks": [{ "type": "italic" }, { "type": "strike" }] },
          { "type": "text", "text": ", " },
          { "type": "text", "text": "굵고 기울이고 밑줄", "marks": [{ "type": "bold" }, { "type": "italic" }, { "type": "underline" }] },
          { "type": "text", "text": " — 마크는 자유롭게 조합 가능합니다." }
        ]
      },

      {
        "type": "heading",
        "attrs": { "level": 2, "id": "text-color-highlight" },
        "content": [{ "type": "text", "text": "텍스트 색상과 하이라이트" }]
      },
      {
        "type": "paragraph",
        "content": [
          { "type": "text", "text": "텍스트 색상: " },
          { "type": "text", "text": "빨간색", "marks": [{ "type": "textStyle", "attrs": { "color": "#e03131" } }] },
          { "type": "text", "text": ", " },
          { "type": "text", "text": "파란색", "marks": [{ "type": "textStyle", "attrs": { "color": "#1971c2" } }] },
          { "type": "text", "text": ", " },
          { "type": "text", "text": "녹색", "marks": [{ "type": "textStyle", "attrs": { "color": "#2f9e44" } }] },
          { "type": "text", "text": ", " },
