  "doc": {
    "type": "doc",
    "content": [
      {
        "type": "heading",
        "attrs": { "level": 1, "id": "feature-guide" },
        "content": [{ "type": "text", "text": "Structured Document Editor — 기능 종합 가이드" }]
      },
      {
        "type": "paragraph",
        "content": [
          { "type": "text", "text": "이 문서는 " },
          { "type": "text", "text": "Structured Document Editor", "marks": [{ "type": "bold" }] },
          { "type": "text", "text": "가 지원하는 " },
          { "type": "text", "text": "모든 기능", "marks": [{ "type": "bold" }, { "type": "italic" }] },
          { "type": "text", "text": "을 종합적으로 보여주는 예시 문서입니다. " },
          { "type": "text", "text": ".sdoc", "marks": [{ "type": "code" }] },
          { "type": "text", "text": " 및 " },
          { "type": "text", "text": ".tiptap.json", "marks": [{ "type": "code" }] },
          { "type": "text", "text": " 파일 포맷으로 작성할 수 있는 모든 노드 타입, 마크, 속성을 포함합니다." }
        ]
      },

      {
        "type": "heading",
        "attrs": { "level": 1, "id": "text-formatting" },
        "content": [{ "type": "text", "text": "텍스트 서식" }]
      },

      {
        "type": "heading",
        "attrs": { "level": 2, "id": "basic-formatting" },
        "content": [{ "type": "text", "text": "기본 서식" }]
      },
      {
        "type": "paragraph",
        "content": [
          { "type": "text", "text": "텍스트에 다양한 서식을 적용할 수 있습니다: " },
          { "type": "text", "text": "굵게(Bold)", "marks": [{ "type": "bold" }] },
          { "type": "text", "text": ", " },
          { "type": "text", "text": "기울임(Italic)", "marks": [{ "type": "italic" }] },
          { "type": "text", "text": ", " },
          { "type": "text", "text": "밑줄(Underline)", "marks": [{ "type": "underline" }] },
          { "type": "text", "text": ", " },
          { "type": "text", "text": "취소선(Strikethrough)", "marks": [{ "type": "strike" }] },
          { "type": "text", "text": ", " },
          { "type": "text", "text": "인라인 코드(Code)", "marks": [{ "type": "code" }] },
          { "type": "text", "text": " 등을 지원합니다." }
        ]
      },

      {
        "type": "heading",
