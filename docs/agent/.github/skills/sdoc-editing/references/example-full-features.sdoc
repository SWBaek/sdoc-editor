        "type": "paragraph",
        "content": [
          { "type": "text", "text": "수학 표기: x" },
          { "type": "text", "text": "2", "marks": [{ "type": "superscript" }] },
          { "type": "text", "text": " + y" },
          { "type": "text", "text": "2", "marks": [{ "type": "superscript" }] },
          { "type": "text", "text": " = r" },
          { "type": "text", "text": "2", "marks": [{ "type": "superscript" }] },
          { "type": "text", "text": ", a" },
          { "type": "text", "text": "n", "marks": [{ "type": "subscript" }] },
          { "type": "text", "text": " = a" },
          { "type": "text", "text": "1", "marks": [{ "type": "subscript" }] },
          { "type": "text", "text": " · r" },
          { "type": "text", "text": "n-1", "marks": [{ "type": "superscript" }] }
